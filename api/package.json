    "@opennextjs/cloudflare": "^1.19.8",
    "@orpc/client": "^1.14.0",
    "@orpc/contract": "^1.14.0",
    "@orpc/json-schema": "^1.14.2",
    "@orpc/openapi": "^1.14.2",
    "@orpc/server": "^1.14.0",
    "@orpc/zod": "^1.14.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.5",
    "dotenv": "^17.4.2",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "pg-cloudflare": "^1.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
